APP_NAME=OnMe
APP_VERSION=0.2.0
ENVIRONMENT=local

# Note: If using Neon, ensure the connection string DOES NOT contain `&channel_binding=require`
# as the SQLAlchemy asyncpg dialect does not currently support it.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/onme
JWT_SECRET=replace-with-a-random-32-plus-character-secret
REPLICATE_API_KEY=replace-with-your-replicate-api-key

ASSET_STORAGE_PATH=./local_uploads
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-project.pages.dev
RATE_LIMIT_STORAGE_URL=memory://
AUTH_RATE_LIMIT=5/minute
TRYON_RATE_LIMIT=5/minute
PORT=8000

# Azure App Service should set:
# ASSET_STORAGE_PATH=/home/data
