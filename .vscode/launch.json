{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Run FastAPI Backend",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "python": "${workspaceFolder}/api/.venv/Scripts/python.exe",
            "args": [
                "api.main:app", 
                "--reload",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ],
            "jinja": true,
            "justMyCode": true,
            "cwd": "${workspaceFolder}"
        }
    ]
}